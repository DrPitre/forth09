: ROMAN
     BEGIN DUP 1000 < IF 1 ELSE 1000 -  77 EMIT       0 THEN UNTIL
     BEGIN DUP  900 < IF 1 ELSE  900 -  67 EMIT 77 EMIT 0 THEN UNTIL
     BEGIN DUP  500 < IF 1 ELSE  500 -  68 EMIT       0 THEN UNTIL
     BEGIN DUP  400 < IF 1 ELSE  400 -  67 EMIT 68 EMIT 0 THEN UNTIL
     BEGIN DUP  100 < IF 1 ELSE  100 -  67 EMIT       0 THEN UNTIL
     BEGIN DUP   90 < IF 1 ELSE   90 -  88 EMIT 67 EMIT 0 THEN UNTIL
     BEGIN DUP   50 < IF 1 ELSE   50 -  76 EMIT       0 THEN UNTIL
     BEGIN DUP   40 < IF 1 ELSE   40 -  88 EMIT 76 EMIT 0 THEN UNTIL
     BEGIN DUP   10 < IF 1 ELSE   10 -  88 EMIT       0 THEN UNTIL
     BEGIN DUP    9 < IF 1 ELSE    9 -  73 EMIT 88 EMIT 0 THEN UNTIL
     BEGIN DUP    5 < IF 1 ELSE    5 -  86 EMIT       0 THEN UNTIL
     BEGIN DUP    4 < IF 1 ELSE    4 -  73 EMIT 86 EMIT 0 THEN UNTIL
     BEGIN DUP    1 < IF 1 ELSE    1 -  73 EMIT       0 THEN UNTIL
     DROP ;

: SHOW  DUP . ." -> "  ROMAN  CR ;

21 1 DO  I SHOW  LOOP

40 SHOW
49 SHOW
